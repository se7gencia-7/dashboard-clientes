// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// CLIENTE - A empresa que usa o dashboard
model Client {
  id        String   @id @default(cuid())
  name      String   // Nome da empresa
  email     String   @unique
  logo      String?  // URL da logo
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações
  users     User[]
  projects  Project[]
  products  Product[]
}

// USUÁRIO - Pessoa que acessa o dashboard
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   @db.Text
  name      String
  role      String   @default("member") // "admin", "manager", "member", "se7_admin", "se7_analyst"
  userType  String   @default("client") // "client" ou "se7_team"

  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// PROJETO - Projeto de anúncios do cliente
model Project {
  id           String   @id @default(cuid())
  name         String
  description  String?
  status       String   @default("ACTIVE")

  clientId     String
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  campaigns    Campaign[]
  audiences    Audience[]
  positionings Positioning[]
  creatives    Creative[]
}

// CAMPANHA - Campanhas do projeto
model Campaign {
  id           String   @id @default(cuid())
  name         String
  status       String   @default("ACTIVE")
  budget       Float
  metaCampaignId String?  @unique

  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  metrics      Metric[]
}

// MÉTRICA - Performance da campanha
model Metric {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  date       DateTime
  reach      Int      @default(0)
  clicks     Int      @default(0)
  conversions Int     @default(0)
  spend      Float    @default(0)
  createdAt  DateTime @default(now())
}

// PRODUTO - Produtos/Serviços do cliente
model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String   // "product", "service"
  price       Float

  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// PÚBLICO (AUDIENCE) - Segmentações de público
model Audience {
  id          String   @id @default(cuid())
  name        String
  description String?

  // Dados demográficos
  ageMin      Int?
  ageMax      Int?
  gender      String?  // "M", "F", "All"
  location    String?  // País, Estado, Cidade
  interests   String?  // JSON array de interesses
  behaviors   String?  // JSON array de comportamentos

  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// POSICIONAMENTO - Mensagens e valores propostos
model Positioning {
  id          String   @id @default(cuid())
  name        String
  tagline     String   // Frase curta (ex: "Moda sustentável")
  mainMessage String   @db.Text // Mensagem principal
  values      String   @db.Text // JSON array com valores
  tone        String   // "profissional", "casual", "divertido", etc

  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// CRIATIVO - Imagens, vídeos, copy
model Creative {
  id          String   @id @default(cuid())
  title       String
  type        String   // "image", "video", "carousel", "text"

  // Conteúdo
  headline    String   // Título do anúncio
  description String?  @db.Text // Descrição
  callToAction String   // CTA (ex: "Compre agora", "Saiba mais")

  // Mídia
  imageUrl    String?  // URL da imagem
  videoUrl    String?  // URL do vídeo

  // Performance
  status      String   @default("draft") // "draft", "active", "archived"

  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
